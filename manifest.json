{
  "manifest_version": 3,
  "name": "Forms Inline Image Preview",
  "version": "1.0.0",
  "description": "Shows Microsoft Forms image upload answers as inline previews for easier review and printing.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Forms Inline Image Preview",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://forms.office.com/*",
        "https://*.forms.office.com/*",
        "https://forms.cloud.microsoft/*",
        "https://*.forms.cloud.microsoft/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
